# ── Sirmmaroc Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# JWT — must be the same secret used by the Auth microservice
JWT_SECRET_KEY=CHANGE_ME_USE_A_STRONG_256_BIT_SECRET_KEY

# Database connection strings (adjust for your DB setup)
AUTH_DATABASE_URL=mysql://user:pass@auth-db:3306/sirmmaroc_auth
ACCOMMODATION_DATABASE_URL=mysql://user:pass@accommodation-db:3306/sirmmaroc_accommodation
TRANSPORT_DATABASE_URL=jdbc:mysql://transport-db:3306/sirmmaroc_transport
MATCHES_DATABASE_URL=Server=matches-db;Database=sirmmaroc_matches;User=user;Password=pass;
TOURISM_DATABASE_URL=mysql://user:pass@tourism-db:3306/sirmmaroc_tourism
COMMUNITY_DATABASE_URL=jdbc:mysql://community-db:3306/sirmmaroc_community


