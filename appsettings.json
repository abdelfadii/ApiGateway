{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Redis": "redis:6379"
  },

  "Jwt": {
    "Issuer": "UserService.Api",
    "Audience": "UserService.Client",
    "SecretKey": "ThisIsASecretKeyForJwtAuthDemo123!"
  },

  "Services": {
    "Auth": {
      "BaseUrl": "http://auth-service:8080"
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
        
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },
      "users-route": {
          "ClusterId": "auth-cluster",
          "AuthorizationPolicy": "anonymous",
          "Match": {
            "Path": "/api/users/{**catch-all}"
          },
          "Transforms": [
            {
              "RequestHeader": "X-Gateway-Source",
              "Set": "SirmarocGateway"
            }
          ]
        },

      "accommodation-route": {
        "ClusterId": "accommodation-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/accommodation/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/accommodation" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "accommodation-public-route": {
        "ClusterId": "accommodation-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/accommodation/search/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/accommodation" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "transport-route": {
        "ClusterId": "transport-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/transport/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/transport" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "matches-route": {
        "ClusterId": "matches-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/matches/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/matches" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "tourism-public-route": {
        "ClusterId": "tourism-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/tourism/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
           { "PathPattern": "/api/{**catch-all}" }, 
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "tourism-route": {
        "ClusterId": "tourism-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/tourism/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "Transforms": [
           { "PathPattern": "/api/{**catch-all}" }, 
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "chatbot-route": {
        "ClusterId": "chatbot-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/chatbot/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/chatbot" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "community-route": {
        "ClusterId": "community-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/community/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/community" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      },

      "admin-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "admin",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/admin" },
          {
            "RequestHeader": "X-Gateway-Source",
            "Set": "SirmarocGateway"
          }
        ]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          }
        },
        "Destinations": {
          "auth-primary": {
            "Address": "http://auth-service:8080"
          }
        }
      },

      "accommodation-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "accommodation-primary": {
            "Address": "http://accommodation-service:8080"
          }
        }
      },

      "transport-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "transport-primary": {
            "Address": "http://transport-service:8080"
          }
        }
      },

      "matches-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "matches-primary": {
            "Address": "http://matches-service:8080"
          }
        }
      },

      "tourism-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "tourism-primary": {
            "Address": "http://symfony-web:80"
          }
        }
      },

      "chatbot-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "chatbot-primary": {
            "Address": "http://chatbot-service:8080"
          }
        }
      },

      "community-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "community-primary": {
            "Address": "http://community-service:8080"
          }
        }
      }
    }
  }
}
